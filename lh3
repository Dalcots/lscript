						airmon-ng start $NII | grep "monitor mode" | awk -F "(" {'print $2'} | cut -d ')' -f1 &> /dev/null && echo -e "${YS}Done${CE}"
						checkmonitor=$(iwconfig ${NII}mon | grep "Mode:Monitor")
						if [[ ${checkmonitor} = "" ]]
						then
							echo -e "$RSCouldn't start monitor mode${CE}"
							sleep 2
							continue
						fi
					fi
					z=1
					l=0
					while [[ ${z} -le "$INTS" ]]
					do
						if [[ ${NII} == "${NI[$z]}" || ${NII} == "$WLANNM" ]]
						then
							echo -e "$RSInterface already set${CE}"
							sleep 2
							l=1
						fi
						z=$((z+1))
					done
					if [[ "$l" = 1 ]]
					then
						continue
					fi
					NI[$INTS]="$NII"
					INTS=$((INTS+1))
				fi
			fi
		done
	fi
done
}
